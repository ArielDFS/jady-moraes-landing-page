# Variáveis de Ambiente — Jady Moraes Leitura Crítica

# ──────────────────────────────────────────────
# Resend API (envio de e-mail do formulário)
# Crie uma conta em https://resend.com
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail que receberá as mensagens do formulário
CONTACT_EMAIL=contato@jadymoraes.com.br

# ──────────────────────────────────────────────
# WhatsApp (número com código do país, sem símbolos)
# Exemplo: 5511999999999
# ──────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=5524999352142

# ──────────────────────────────────────────────
# Redes Sociais
# ──────────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/jadymoraes

# ──────────────────────────────────────────────
# URL do site (para SEO e OpenGraph)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jadymoraes.com.br
